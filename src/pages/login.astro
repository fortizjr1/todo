---
import AuthLayout from '../layouts/AuthLayout.astro';

const API_URL = import.meta.env.PUBLIC_API_URL || '/api';
---

<AuthLayout title="Login - Task Manager">
  <div class="min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-md">
      <div class="border-2 border-black p-8">
        <h1 class="font-mono text-3xl font-bold mb-2 tracking-tight">
          TASK<span class="text-accent">.MANAGER</span>
        </h1>
        <p class="font-mono text-sm text-gray-600 mb-8 border-b-2 border-black pb-4">
          // ENTER CREDENTIALS
        </p>

        <form id="login-form" class="space-y-4">
          <div>
            <label class="font-mono text-xs uppercase block mb-1" for="email">
              Email
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border-2 border-black p-3 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
              placeholder="email@example.com"
            />
          </div>

          <div>
            <label class="font-mono text-xs uppercase block mb-1" for="password">
              Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="w-full border-2 border-black p-3 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
              placeholder="********"
            />
          </div>

          <div>
            <label class="font-mono text-xs uppercase block mb-1" for="username-register">
              Username (register only)
            </label>
            <input
              type="text"
              id="username-register"
              name="username"
              class="w-full border-2 border-black p-3 font-mono text-sm focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2"
              placeholder="new_username"
            />
          </div>

          <div class="flex gap-4 pt-2">
            <button
              type="submit"
              name="action"
              value="login"
              class="flex-1 bg-black text-white font-mono text-sm uppercase py-3 px-4 hover:bg-accent transition-colors"
            >
              Login
            </button>
            <button
              type="submit"
              name="action"
              value="register"
              class="flex-1 border-2 border-black font-mono text-sm uppercase py-3 px-4 hover:bg-gray-100 transition-colors"
            >
              Register
            </button>
          </div>

          <div id="error-message" class="hidden font-mono text-xs text-red-600 mt-4 p-2 bg-red-50 border border-red-600"></div>
        </form>
      </div>
    </div>
  </div>

  <script define:vars={{ API_URL }}>
    const form = document.getElementById('login-form');
    const errorDiv = document.getElementById('error-message');

    function getApiUrl() {
      return API_URL;
    }

    function saveToken(token) {
      localStorage.setItem('auth_token', token);
    }

    function getToken() {
      return localStorage.getItem('auth_token');
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const email = formData.get('email');
      const password = formData.get('password');
      const username = formData.get('username');
      const action = formData.get('action');

      if (errorDiv) {
        errorDiv.classList.add('hidden');
        errorDiv.textContent = '';
      }

      try {
        if (action === 'register') {
          if (!username) {
            throw new Error('Username is required for registration');
          }
          
          const res = await fetch(`${getApiUrl()}/auth/register`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password, username })
          });
          
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Registration failed');
          
          saveToken(data.token);
          window.location.href = '/dashboard';
        } else {
          const res = await fetch(`${getApiUrl()}/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
          });
          
          const data = await res.json();
          if (!res.ok) throw new Error(data.error || 'Login failed');
          
          saveToken(data.token);
          window.location.href = '/dashboard';
        }
      } catch (err) {
        if (errorDiv) {
          errorDiv.classList.remove('hidden');
          errorDiv.textContent = `ERROR: ${err.message}`;
        }
      }
    });
  </script>
</AuthLayout>
